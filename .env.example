# === Database (PostgreSQL / Supabase) ===
# Port 6543 = Supabase transaction pooler (PgBouncer). Untuk migrasi Flyway
# yang bermasalah, pakai session pooler / direct connection (port 5432).
DB_HOST=
DB_PORT=6543
DB_NAME=postgres
DB_USERNAME=
DB_PASSWORD=
# Opsional tuning Hikari
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# === Redis (Upstash / lokal) ===
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
# Upstash butuh TLS -> true. Redis lokal tanpa TLS -> false.
REDIS_SSL=true

# === Server ===
SERVER_PORT=8080

# === CORS ===
# Origin frontend (Next.js). Pisahkan dengan koma untuk multi-origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# === Logging (opsional) ===
LOG_LEVEL_APP=INFO
LOG_LEVEL_SQL=WARN
